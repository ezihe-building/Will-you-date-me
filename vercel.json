{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/date-with-me run build",
  "outputDirectory": "artifacts/date-with-me/dist/public",
  "env": {
    "BASE_PATH": "/"
  },
  "functions": {
    "api/index.mjs": {
      "runtime": "nodejs22.x",
      "includeFiles": "api/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
