{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/date-with-me run build",
  "outputDirectory": "artifacts/date-with-me/dist/public",
  "env": {
    "BASE_PATH": "/",
    "PORT": "3000"
  },
  "functions": {
    "artifacts/api-server/api/index.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
